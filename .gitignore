# .gitignore do 2048-master
.sass-cache/

# Windows - Arquivos do sistema e miniaturas
Thumbs.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# Web & Node.js - Padrões de desenvolvimento
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.stylelintcache

# Editores de Código (VS Code, Sublime, etc)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Arquivos temporários e compactados
*.zip
*.rar
*.7z
*.log
tmp/
temp/

# Arquivos específicos do Apache (se gerados na pasta)
.htaccess.bak
error_log
access_log